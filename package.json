{
  "name": "snowdrift",
  "version": "0.1.0",
  "description": "SnowDrift WorkSpace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --recursive --filter @snowdrift/* build",
    "dev:webui": "pnpm --filter @snowdrift/webui dev",
    "test": "pnpm --recursive --filter @snowdrift/* test",
    "typecheck": "pnpm --recursive --filter @snowdrift/* typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
